pub fn should_log(action: Action, role: Role, dry_run: bool) -> bool {
    match action {
        Action::Delete => !dry_run,
        Action::Create | Action::Update => match role {
            Role::Admin => true,
            Role::User => !dry_run,
            Role::Guest => false,
        },
    }
}

