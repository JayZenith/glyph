pub fn parse_record(line: &str) -> Result<(&str, &str), &'static str> {
    let line = line.trim();
    if line.is_empty() {
        return Err("empty line");
    }

    let Some((key, value)) = line.split_once('=') else {
        return Err("missing separator");
    };

    let key = key.trim();
    let value = value.trim();

    if key.is_empty() {
        return Err("empty key");
    }

    Ok((key, value))
}

