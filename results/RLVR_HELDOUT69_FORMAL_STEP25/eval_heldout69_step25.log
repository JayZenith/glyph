pub fn active_even_name_lengths(items: &[(&str, bool)]) -> Vec<usize> {
    items
        .iter()
        .filter(|(_, active)| !*active)
        .map(|(name, _)| name.len())
        .filter(|len| len % 2 == 0)
        .collect()
}

